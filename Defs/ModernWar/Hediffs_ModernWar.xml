<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <HediffDef>
    <defName>HD_ZaperX26_Shock</defName>
    <label>ZAPER electroshock</label>
    <description>Two wired probes are delivering repeated electrical pulses, causing severe pain and disrupting voluntary movement.</description>
    <defaultLabelColor>(0.55,0.75,1.0)</defaultLabelColor>
    <isBad>true</isBad>
    <stages>
      <li>
        <painOffset>0.60</painOffset>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.75</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.70</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HD_ZaperX26_ContactShock</defName>
    <label>ZAPER contact shock</label>
    <description>A direct discharge from the weapon's contact electrodes is causing intense, short-lived pain.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <defaultLabelColor>(0.55,0.75,1.0)</defaultLabelColor>
    <isBad>true</isBad>
    <comps>
      <li Class="HediffCompProperties_Disappears">
        <disappearsAfterTicks>120~120</disappearsAfterTicks>
        <showRemainingTime>true</showRemainingTime>
      </li>
    </comps>
    <stages>
      <li>
        <painOffset>0.85</painOffset>
      </li>
    </stages>
  </HediffDef>

</Defs>
