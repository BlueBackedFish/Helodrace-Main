        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
    <costList>
      <Steel>20</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <workSkill>Crafting</workSkill>
      <skillRequirements>
        <Crafting>4</Crafting>
      </skillRequirements>
      <researchPrerequisite>MicroelectronicsBasics</researchPrerequisite>
