  <ThingDef ParentName="ApparelNoQualityBase">
    <defName>HD_Apparel_ZaperX26</defName>
    <label>ZAPER X26</label>
    <description>A compact electroshock sidearm carried as auxiliary equipment. Its dedicated controls fire a paired set of wired probes or deliver a direct contact-electrode strike without replacing the wearer's primary weapon.</description>
    <graphicData>
      <texPath>Weapon/ModernWar/HD_TASERX26</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.65,0.65)</drawSize>
    </graphicData>
    <statBases>
      <WorkToMake>9000</WorkToMake>
      <Mass>0.9</Mass>
      <MarketValue>420</MarketValue>
      <MaxHitPoints>100</MaxHitPoints>
      <EquipDelay>0.8</EquipDelay>
    </statBases>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <apparel>
      <bodyPartGroups>
        <li>Waist</li>
      </bodyPartGroups>
      <useWornGraphicMask>false</useWornGraphicMask>
      <parentTagDef>ApparelBody</parentTagDef>
      <layers>
        <li>Belt</li>
      </layers>
      <tags>
        <li>HD_Apparel</li>
        <li>Soldier</li>
      </tags>
