<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BaseBullet">
    <defName>HD_ZaperX26_Probe</defName>
    <label>ZAPER X26 probe</label>
    <thingClass>Helodrace.ModernWar.Projectile_ZaperX26Probe</thingClass>
    <graphicData>
      <texPath>Weapon/ModernWar/Proj/HD_TASERProbe_proj</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.28,0.28)</drawSize>
    </graphicData>
    <projectile>
      <!-- Only a probe that actually creates a bullet wound counts toward activation. -->
      <damageDef>Bullet</damageDef>
      <damageAmountBase>1</damageAmountBase>
      <armorPenetrationBase>0.08</armorPenetrationBase>
      <speed>54</speed>
    </projectile>
  </ThingDef>

  <ThingDef>
    <defName>HD_ZaperX26_TetherEffect</defName>
    <label>ZAPER X26 active tether</label>
    <thingClass>Helodrace.ModernWar.ZaperX26TetherEffect</thingClass>
    <category>Ethereal</category>
    <tickerType>Normal</tickerType>
    <drawerType>RealtimeOnly</drawerType>
    <selectable>false</selectable>
    <useHitPoints>false</useHitPoints>
    <altitudeLayer>MoteOverhead</altitudeLayer>
  </ThingDef>

  <ThingDef ParentName="BaseHumanMakeableGun">
    <defName>HD_Gun_ZaperX26</defName>
    <label>ZAPER X26</label>
    <description>A compact electroshock weapon that launches two wired probes in rapid succession. Both probes must inflict a gunshot wound on the same target to complete the circuit. In close combat its exposed contact electrodes can deliver a brief, intensely painful shock.</description>
    <graphicData>
      <texPath>Weapon/ModernWar/HD_TASERX26</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.65,0.65)</drawSize>
    </graphicData>
    <equippedAngleOffset>0</equippedAngleOffset>
    <soundInteract>Interact_Rifle</soundInteract>
    <weaponClasses>
      <li>RangedLight</li>
    </weaponClasses>
    <weaponTags>
      <li>HD_ModernWarWeapon</li>
      <li>IndustrialGunAdvanced</li>
    </weaponTags>
    <statBases>
      <WorkToMake>9000</WorkToMake>
      <Mass>0.9</Mass>
      <MarketValue>420</MarketValue>
      <MaxHitPoints>100</MaxHitPoints>
      <AccuracyTouch>1.00</AccuracyTouch>
      <AccuracyShort>0.98</AccuracyShort>
      <AccuracyMedium>0.80</AccuracyMedium>
      <AccuracyLong>0.60</AccuracyLong>
      <RangedWeapon_Cooldown>2.4</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>20</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <recipeMaker>
      <skillRequirements>
        <Crafting>4</Crafting>
      </skillRequirements>
      <researchPrerequisite>MicroelectronicsBasics</researchPrerequisite>
    </recipeMaker>
    <comps>
      <li Class="Helodrace.ModernWar.CompProperties_ZaperX26" />
      <li Class="Helodrace.CompProperties_SharpshooterWeapon">
        <altVerbIndex>1</altVerbIndex>
        <altCooldownMultiplier>1.0</altCooldownMultiplier>
        <altAccuracyMultiplier>0.92</altAccuracyMultiplier>
        <switchTicks>30</switchTicks>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Helodrace.ModernWar.Verb_ShootZaperX26</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_ZaperX26_Probe</defaultProjectile>
        <warmupTime>0.35</warmupTime>
        <range>7.9</range>
        <requireLineOfSight>true</requireLineOfSight>
        <burstShotCount>2</burstShotCount>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <muzzleFlashScale>0.25</muzzleFlashScale>
      </li>
      <li>
        <verbClass>Helodrace.ModernWar.Verb_ShootZaperX26</verbClass>
        <hasStandardCommand>false</hasStandardCommand>
        <defaultProjectile>HD_ZaperX26_Probe</defaultProjectile>
        <warmupTime>0.08</warmupTime>
        <range>6.9</range>
        <requireLineOfSight>true</requireLineOfSight>
        <burstShotCount>2</burstShotCount>
        <ticksBetweenBurstShots>1</ticksBetweenBurstShots>
        <muzzleFlashScale>0.25</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>contact electrodes</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>1</power>
        <cooldownTime>1.5</cooldownTime>
        <chanceFactor>10</chanceFactor>
        <alwaysTreatAsWeapon>true</alwaysTreatAsWeapon>
      </li>
    </tools>
  </ThingDef>

  <ThingDef>
    <defName>HD_Switchblade600_Drone</defName>
    <label>Switchblade 600 drone</label>
    <thingClass>Helodrace.SwitchbladeDrone</thingClass>
    <category>Projectile</category>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <altitudeLayer>MoteOverhead</altitudeLayer>
    <useHitPoints>false</useHitPoints>
    <selectable>false</selectable>
    <graphicData>
      <texPath>Weapon/ModernWar/Proj/HD_SwitchBlade600_FullBlade</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.1,1.1)</drawSize>
    </graphicData>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>HD_Switchblade600_Proj</defName>
    <label>Switchblade 600 loitering munition</label>
    <thingClass>Helodrace.Projectile_Switchblade600</thingClass>
    <graphicData>
      <texPath>Weapon/ModernWar/Proj/HD_SwitchBlade600_FullBlade</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.1,1.1)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>110</damageAmountBase>
      <armorPenetrationBase>1.80</armorPenetrationBase>
      <stoppingPower>3.2</stoppingPower>
      <speed>38</speed>
      <flyOverhead>true</flyOverhead>
      <explosionRadius>2.4</explosionRadius>
      <soundExplode>Explosion_Bomb</soundExplode>
    </projectile>
    <modExtensions>
      <li Class="Helodrace.Switchblade600ProjectileExtension">
        <smokeTrailIntervalTicks>14</smokeTrailIntervalTicks>
        <smokeTrailSize>0.35</smokeTrailSize>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseWeaponTurret">
    <defName>HD_Gun_Switchblade600Launcher_TurretGun</defName>
    <label>Switchblade 600 launcher</label>
    <description>A compact launch canister for Switchblade 600 loitering munitions. This early implementation fires a single long-range overhead strike and is reserved for spawning or scenario use.</description>
    <graphicData>
      <texPath>Building/Security/HD_SwitchBlade600_Canister</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.25,1.25)</drawSize>
    </graphicData>
    <statBases>
      <AccuracyTouch>0.15</AccuracyTouch>
      <AccuracyShort>0.45</AccuracyShort>
      <AccuracyMedium>0.72</AccuracyMedium>
      <AccuracyLong>0.86</AccuracyLong>
      <RangedWeapon_Cooldown>18.0</RangedWeapon_Cooldown>
    </statBases>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <defaultProjectile>HD_Switchblade600_Proj</defaultProjectile>
        <warmupTime>5.0</warmupTime>
        <range>24.9</range>
        <requireLineOfSight>false</requireLineOfSight>
        <burstShotCount>1</burstShotCount>
        <targetParams>
          <canTargetLocations>true</canTargetLocations>
        </targetParams>
        <soundCast>Mortar_LaunchA</soundCast>
        <muzzleFlashScale>5</muzzleFlashScale>
        <forcedMissRadius>1.2</forcedMissRadius>
      </li>
    </verbs>
    <comps>
      <li Class="CompProperties_ChangeableProjectile" />
    </comps>
    <building>
      <fixedStorageSettings>
        <filter>
          <thingDefs>
            <li>HD_Switchblade600_Round</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <filter>
          <thingDefs>
            <li>HD_Switchblade600_Round</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
    </building>
  </ThingDef>

</Defs>
