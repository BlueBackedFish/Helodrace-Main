<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <JobDef>
    <defName>HD_BoardAircraftPilot</defName>
    <driverClass>Helodrace.Aircraft.JobDriver_BoardAircraft</driverClass>
    <reportString>boarding TargetA as pilot.</reportString>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

  <JobDef>
    <defName>HD_BoardAircraftPassenger</defName>
    <driverClass>Helodrace.Aircraft.JobDriver_BoardAircraft</driverClass>
    <reportString>boarding TargetA.</reportString>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

  <JobDef>
    <defName>HD_LoadAircraftCargo</defName>
    <driverClass>Helodrace.Aircraft.JobDriver_LoadAircraftCargo</driverClass>
    <reportString>loading TargetB into TargetA.</reportString>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

  <JobDef>
    <defName>HD_LoadAircraftBomb</defName>
    <driverClass>Helodrace.Aircraft.JobDriver_LoadAircraftBomb</driverClass>
    <reportString>loading TargetB into TargetA's bomb bay.</reportString>
    <casualInterruptible>false</casualInterruptible>
  </JobDef>

  <WorkGiverDef>
    <defName>HD_LoadAircraftCargo</defName>
    <giverClass>Helodrace.Aircraft.WorkGiver_LoadAircraftCargo</giverClass>
    <workType>Hauling</workType>
    <priorityInType>95</priorityInType>
    <verb>load aircraft cargo</verb>
    <gerund>loading aircraft cargo</gerund>
    <scanThings>true</scanThings>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <WorkGiverDef>
    <defName>HD_LoadAircraftBombs</defName>
    <giverClass>Helodrace.Aircraft.WorkGiver_LoadAircraftBombs</giverClass>
    <workType>Hauling</workType>
    <priorityInType>96</priorityInType>
    <verb>load aircraft bombs</verb>
    <gerund>loading aircraft bombs</gerund>
    <scanThings>true</scanThings>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

</Defs>
