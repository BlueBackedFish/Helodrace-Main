<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!--
    Abstract base only: this does not add a playable aircraft by itself.
    Concrete aircraft supply their own texture, size, stats and construction data.
  -->
  <ThingDef Name="HD_AircraftBase" Abstract="True">
    <thingClass>Helodrace.Aircraft.AircraftThing</thingClass>
    <category>Item</category>
    <drawerType>RealtimeOnly</drawerType>
    <tickerType>Normal</tickerType>
    <selectable>true</selectable>
    <rotatable>true</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.1</fillPercent>
    <useHitPoints>true</useHitPoints>
    <alwaysHaulable>false</alwaysHaulable>
    <inspectorTabs>
      <li>Helodrace.Aircraft.ITab_AircraftStatus</li>
      <li>ITab_ContentsTransporter</li>
    </inspectorTabs>
    <statBases>
      <MaxHitPoints>500</MaxHitPoints>
      <Flammability>0.5</Flammability>
    </statBases>
    <modExtensions>
      <li Class="Helodrace.Aircraft.AircraftDefExtension">
        <cruiseAltitude>18</cruiseAltitude>
      </li>
    </modExtensions>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>250</fuelCapacity>
        <fuelConsumptionRate>0.0005</fuelConsumptionRate>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <initialFuelPercent>0</initialFuelPercent>
        <initialConfigurableTargetFuelLevel>250</initialConfigurableTargetFuelLevel>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <showFuelGizmo>true</showFuelGizmo>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <initialAllowAutoRefuel>true</initialAllowAutoRefuel>
        <hideGizmosIfNotPlayerFaction>false</hideGizmosIfNotPlayerFaction>
        <fuelLabel>HD_Aircraft_FuelLabel</fuelLabel>
        <fuelGizmoLabel>HD_Aircraft_FuelGizmoLabel</fuelGizmoLabel>
        <fuelFilter>
          <thingDefs>
            <li>Chemfuel</li>
            <li>WoodLog</li>
          </thingDefs>
        </fuelFilter>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftFuelSelector" />
      <li Class="Helodrace.Aircraft.CompProperties_AircraftManifest">
        <passengerCapacity>4</passengerCapacity>
        <cargoCapacity>500</cargoCapacity>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftTransporter">
        <massCapacity>500</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <shouldTickContents>true</shouldTickContents>
        <showMassInInspectString>true</showMassInInspectString>
        <showOverallStats>true</showOverallStats>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftBombBay">
        <capacity>1000</capacity>
        <allowedBombTags>
          <li>HD_AircraftBomb</li>
        </allowedBombTags>
      </li>
    </comps>
  </ThingDef>

</Defs>
