  <!-- Naphtha -->
  <ThingDef ParentName="ResourceBase">
    <defName>HD_Naphtha</defName>
    <label>naphtha</label>
    <description>A volatile light petroleum fraction distilled from crude oil. It contains trace BTX compounds, but drinking it leaves a foul oily taste and smell.</description>
    <descriptionHyperlinks>
      <HediffDef>HD_BTXHigh</HediffDef>
    </descriptionHyperlinks>
    <graphicData>
      <texPath>Item/HD_Naphtha</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <stackLimit>150</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <statBases>
      <MaxHitPoints>45</MaxHitPoints>
      <MarketValue>5.0</MarketValue>
      <Mass>0.06</Mass>
      <Flammability>2.6</Flammability>
      <DeteriorationRate>1</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <ingestible>
      <preferability>NeverForNutrition</preferability>
      <foodType>Processed</foodType>
      <drugCategory>Medical</drugCategory>
      <ingestCommandString>Drink naphtha</ingestCommandString>
      <ingestReportString>Drinking naphtha.</ingestReportString>
      <maxNumToIngestAtOnce>1</maxNumToIngestAtOnce>
      <tasteThought>HD_DrankNaphtha</tasteThought>
      <outcomeDoers>
        <li Class="IngestionOutcomeDoer_GiveHediff">
          <hediffDef>HD_BTXHigh</hediffDef>
          <severity>0.35</severity>
          <toleranceChemical>BTX</toleranceChemical>
        </li>
      </outcomeDoers>
    </ingestible>
    <comps>
      <li Class="CompProperties_Drug">
        <chemical>BTX</chemical>
        <addictiveness>0</addictiveness>
        <needLevelOffset>0.9</needLevelOffset>
        <listOrder>1006</listOrder>
        <overdoseSeverityOffset>0.02~0.04</overdoseSeverityOffset>
      </li>
    </comps>
  </ThingDef>

