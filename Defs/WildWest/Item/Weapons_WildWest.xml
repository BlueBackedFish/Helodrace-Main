  <!-- ==================== Weapons ==================== -->

  <ThingDef ParentName="BaseMakeableGun">
    <defName>HD_Gun_ColtSAA_Weapon</defName>
    <weaponTags>
      <li>HD_WildWestRevolver</li>
    </weaponTags>
    <label>Ironfang SAA</label>
    <description>A six-shot single-action revolver made by Ironfang Arms.</description>
    <graphicData>
      <texPath>Weapon/WildWest/ColtSAA</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.7,0.7)</drawSize>
    </graphicData>
    <soundInteract>Interact_Revolver</soundInteract>
    <statBases>
      <WorkToMake>15000</WorkToMake>
      <Mass>1.05</Mass>
      <AccuracyTouch>0.80</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.50</AccuracyMedium>
      <AccuracyLong>0.35</AccuracyLong>
      <RangedWeapon_Cooldown>1.6</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>30</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <recipeMaker Inherit="False" IsNull="True" />

    <comps>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
      <li Class="Helodrace.CompProperties_SharpshooterWeapon">
        <altVerbIndex>1</altVerbIndex>
        <altCooldownMultiplier>4</altCooldownMultiplier>
        <altModeLabelKey>HD_SharpshooterMode_Fanning</altModeLabelKey>
        <modeDescriptionKey>HD_SharpshooterMode_Fanning_Desc</modeDescriptionKey>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_Bullet_ColtSAA_Proj</defaultProjectile>
        <warmupTime>0.3</warmupTime>
        <range>25.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>HD_HighCaliberpistol</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>false</hasStandardCommand>
        <defaultProjectile>HD_Bullet_ColtSAA_Proj</defaultProjectile>
        <warmupTime>0.1</warmupTime>
        <range>6.9</range>
        <burstShotCount>6</burstShotCount>
        <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
        <soundCast>HD_HighCaliberpistol</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
      <li>
        <label>barrel</label>
        <capacities>
          <li>Blunt</li>
          <li>Poke</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

