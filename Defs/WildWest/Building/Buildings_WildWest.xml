  <ThingDef ParentName="BuildingBase">
    <defName>HD_LineShaft</defName>
    <label>line shaft</label>
    <description>A system of rotating shafts used to transmit mechanical power from a steam engine to other machines.</description>
    <thingClass>Building</thingClass>
    <category>Building</category>
    <graphicData>
      <texPath>Things/Building/Linked/PowerConduit_Atlas</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <linkType>Transmitter</linkType>
      <linkFlags>
        <li>PowerConduit</li>
      </linkFlags>
      <damageData>
        <rect>(0,0.35,1,0.3)</rect>
      </damageData>
    </graphicData>
    <uiIconPath>Things/Building/Linked/PowerConduit_MenuIcon</uiIconPath>
    <building>
      <isInert>true</isInert>
      <isEdifice>false</isEdifice>
