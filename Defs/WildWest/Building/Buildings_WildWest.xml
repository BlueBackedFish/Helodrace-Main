<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>HD_CableToolRig</defName>
    <label>cable-tool rig</label>
    <description>A traditional drilling rig using a heavy bit suspended by a cable to pound through
      rock. Used for finding water or oil in the frontier.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Building/HD_CableToolRig</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(5,5)</drawSize>
      <drawOffset>(0.4,0,1.2)</drawOffset>
      <shaderType>CutoutComplex</shaderType>
      <shadowData>
        <volume>(2.8, 0.6, 2.8)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <blockWind>true</blockWind>
    <fillPercent>1.0</fillPercent>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>2500</WorkToBuild>
      <Flammability>1.5</Flammability>
      <Mass>100</Mass>
    </statBases>
    <stuffCategories>
      <li>Woody</li>
    </stuffCategories>
    <costStuffCount>150</costStuffCount>
    <size>(4,3)</size>
    <rotatable>false</rotatable>
    <designationCategory>HD_HelodTechnology_Build</designationCategory>
    <uiOrder>2000</uiOrder>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Heavy</terrainAffordanceNeeded>
    <researchPrerequisites>
      <li>HelodBasicOilDevelopment</li>
    </researchPrerequisites>
    <tickerType>Normal</tickerType>
    <building>
      <buildingTags>
        <li>HD_SteamEnginePowered</li>
      </buildingTags>
    </building>
    <inspectorTabs>
      <li>Helodrace.ITab_MechanicalNetwork</li>
    </inspectorTabs>
    <comps>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>0</explosiveRadius>
        <explosiveExpandPerFuel>0.95</explosiveExpandPerFuel>
        <explosiveDamageType>Flame</explosiveDamageType>
        <destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
        <startWickHitPointsPercent>0.333</startWickHitPointsPercent>
        <preExplosionSpawnThingDef>Filth_Fuel</preExplosionSpawnThingDef>
        <preExplosionSpawnChance>1</preExplosionSpawnChance>
        <wickTicks>70~150</wickTicks>
      </li>
      <li Class="Helodrace.CompProperties_MechanicalUser">
        <powerConsumed>0</powerConsumed>
        <requireTorque>300</requireTorque>
        <minimalRPM>100</minimalRPM>
        <recommendedRPM>100</recommendedRPM>
        <defaultGearRatio>1.0</defaultGearRatio>
      </li>
      <li Class="Helodrace.CompProperties_OperatingHeatPusher">
        <heatPerSecond>2</heatPerSecond>
        <heatPushMaxTemperature>45</heatPushMaxTemperature>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="Helodrace.CompProperties_OilFieldDevelopment" />
    </comps>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>HD_SmallSteamEngine</defName>
    <label>small steam engine</label>
    <description>A compact, coal-fired steam engine designed to provide mechanical power to nearby
      machinery. It must be placed near a compatible building to function.</description>
    <thingClass>Building</thingClass>
    <graphicData>
      <texPath>Building/HD_SmallSteamEngine</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <shaderType>CutoutComplex</shaderType>
      <drawSize>(3.3,3.3)</drawSize>
      <drawOffset>(0,0,0.3)</drawOffset>
      <shadowData>
        <volume>(1.8, 0.5, 1.8)</volume>
      </shadowData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>Impassable</passability>
    <fillPercent>1.0</fillPercent>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>1500</WorkToBuild>
      <Flammability>1.0</Flammability>
      <Mass>60</Mass>
    </statBases>
    <stuffCategories>
      <li>Metallic</li>
    </stuffCategories>
    <costStuffCount>75</costStuffCount>
    <costList>
      <HD_PigIron>40</HD_PigIron>
    </costList>
    <size>(2,2)</size>
    <rotatable>false</rotatable>
    <designationCategory>HD_HelodTechnology_Build</designationCategory>
    <uiOrder>2100</uiOrder>
    <constructionSkillPrerequisite>8</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <researchPrerequisites>
      <li>HelodSteamEngine</li>
    </researchPrerequisites>
    <tickerType>Normal</tickerType>
    <inspectorTabs>
      <li>Helodrace.ITab_MechanicalNetwork</li>
    </inspectorTabs>
    <comps>
      <li Class="Helodrace.CompProperties_MechanicalEmitter">
        <maxPossiblePower>1200</maxPossiblePower>
        <recommendedPower>1000</recommendedPower>
        <sourceType>SteamEngine</sourceType>
        <maxRPM>500</maxRPM>
        <lowestRPM>50</lowestRPM>
        <rpmInaccuracy>10</rpmInaccuracy>
      </li>
      <li Class="CompProperties_Flickable"/>
      <li Class="CompProperties_Refuelable">
        <fuelConsumptionRate>50.0</fuelConsumptionRate>
        <fuelCapacity>25.0</fuelCapacity>
        <fuelFilter>
          <thingDefs>
            <li>WoodLog</li>
          </thingDefs>
        </fuelFilter>
        <showFuelGizmo>true</showFuelGizmo>
        <fuelLabel>Wood</fuelLabel>
        <fuelGizmoLabel>Wood fuel</fuelGizmoLabel>
        <outOfFuelMessage>Cannot function: Out of wood</outOfFuelMessage>
      </li>
      <li Class="Helodrace.CompProperties_OperatingHeatPusher">
        <heatPerSecond>12</heatPerSecond>
        <heatPushMaxTemperature>85</heatPushMaxTemperature>
      </li>
      <li Class="CompProperties_Explosive">
        <explosiveRadius>9.9</explosiveRadius>
        <explosiveDamageType>Bomb</explosiveDamageType>
        <destroyThingOnExplosionSize>2</destroyThingOnExplosionSize>
        <startWickHitPointsPercent>0.5</startWickHitPointsPercent>
        <wickTicks>200~240</wickTicks>
      </li>
      <li Class="Helodrace.CompProperties_SteamEngineSmoke">
        <smokeOffset>(0.5, 0, 2)</smokeOffset>
      </li>
    </comps>
  </ThingDef>

