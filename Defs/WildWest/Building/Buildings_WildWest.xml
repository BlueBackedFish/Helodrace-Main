    <comps>
      <li Class="Helodrace.CompProperties_MechanicalTransmitter" />
    </comps>
    <designationCategory>HD_HelodTechnology_Build</designationCategory>
    <uiOrder>2050</uiOrder>
    <researchPrerequisites>
      <li>HelodLineShaft</li>
    </researchPrerequisites>
