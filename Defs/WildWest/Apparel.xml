<Defs>

  <ThingDef ParentName="ApparelBase">
    <defName>HD_Apparel_CarvalyUniform</defName>
    <label>Carvaly uniform</label>
    <description>A standard uniform for Carvaly officers. Designed specifically for the Helod body type. Gives bonuses to movement speed and melee combat.</description>
    <graphicData>
      <texPath>Dogos/Appearel/HD_Carvaly_Female_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(255,255,255)</color>
    </graphicData>
