  <ThingDef ParentName="ApparelBase">
    <defName>HD_Apparel_CowboyHat</defName>
    <label>Cowboy hat</label>
    <description>A stylish cowboy hat that has a split design to accommodate ears on the sides when facing east and west.</description>
    <graphicData>
      <texPath>Dogos/Appearel/HD_CowboyHat_south</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <color>(255,255,255)</color>
    </graphicData>
    <statBases>
      <MaxHitPoints>80</MaxHitPoints>
      <WorkToMake>1200</WorkToMake>
      <Mass>0.1</Mass>
      <ArmorRating_Sharp>0.1</ArmorRating_Sharp>
      <ArmorRating_Blunt>0.05</ArmorRating_Blunt>
      <ArmorRating_Heat>0.05</ArmorRating_Heat>
      <Insulation_Cold>2</Insulation_Cold>
      <Insulation_Heat>2</Insulation_Heat>
      <EquipDelay>0.8</EquipDelay>
    </statBases>
    <equippedStatOffsets>
      <ShootingAccuracyPawn>1</ShootingAccuracyPawn>
    </equippedStatOffsets>
    <thingCategories>
      <li>Headgear</li>
    </thingCategories>
    <apparel>
      <bodyPartGroups>
        <li>UpperHead</li>
      </bodyPartGroups>
      <wornGraphicPath>Dogos/Appearel/HD_CowboyHat</wornGraphicPath>
      <layers>
        <li>Overhead</li>
      </layers>
      <tags>
        <li>HD_Apparel</li>
        <li>HD_Apparel_WW_WatchmanHeadgear</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
        <li>Soldier</li>
      </defaultOutfitTags>
      <renderNodeProperties>
        <!-- 1. Base/Back Hat Layer (drawn behind the ears/head when facing East/West) -->
        <li>
          <nodeClass>PawnRenderNode_Apparel</nodeClass>
          <workerClass>PawnRenderNodeWorker_Apparel_Head</workerClass>
          <parentTagDef>Head</parentTagDef>
          <drawData>
            <dataEast>
              <layer>50</layer> <!-- Renders behind the ears (which render at layer ~50.02) -->
            </dataEast>
            <dataWest>
              <layer>50</layer> <!-- Renders behind the ears -->
            </dataWest>
          </drawData>
        </li>
        <!-- 2. Front Brim Layer (drawn in front of the ears when facing East/West) -->
        <li>
          <nodeClass>PawnRenderNode</nodeClass>
          <workerClass>PawnRenderNodeWorker</workerClass>
          <parentTagDef>Head</parentTagDef>
          <baseLayer>92</baseLayer>
          <texPath>Dogos/Appearel/HD_CowboyHat_Front</texPath>
          <drawData>
            <dataEast>
              <layer>92</layer>
            </dataEast>
            <dataWest>
              <layer>92</layer>
            </dataWest>
          </drawData>
        </li>
      </renderNodeProperties>
    </apparel>
    <recipeMaker>
      <workSkill>Crafting</workSkill>
      <recipeUsers>
        <li>ElectricTailoringBench</li>
        <li>HandTailoringBench</li>
      </recipeUsers>
    </recipeMaker>
    <costList>
      <Cloth>20</Cloth>
    </costList>
  </ThingDef>

