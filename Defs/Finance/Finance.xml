<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Sthaler Banknote -->
  <ThingDef ParentName="ResourceBase">
    <defName>HD_Money</defName>
    <label>sthaler banknote</label>
    <description>A beautifully engraved paper banknote used as the standard currency among Helod settlements. Known as Sthaler, it carries significant value but is highly fragile and will dissolve quickly if left unroofed in the rain.</description>
    <graphicData>
      <texPath>Item/HD_Money</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>5000</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>5.0</MarketValue> <!-- Half the value of Gold (which is 10.0) -->
      <Mass>0.0001</Mass> <!-- 0.1g = 0.0001 kg (paper banknote) -->
      <Flammability>1.5</Flammability>
      <DeteriorationRate>10</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>ResourcesValue</li>
    </thingCategories>
  </ThingDef>

  <!-- Government Bond -->
  <ThingDef ParentName="ResourceBase">
    <defName>HD_GovernmentBond</defName>
    <label>government bond</label>
    <description>An official, beautifully engraved paper government bond certificate issued by the United States of Vesenica. It serves as high-value, secure sovereign wealth storage. It cannot be stacked and must be handled with care.</description>
    <graphicData>
      <texPath>Item/HD_GovernmentBond</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>10</stackLimit> <!-- Can stack up to 10 -->
    <healthAffectsPrice>false</healthAffectsPrice>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>1000.0</MarketValue> <!-- Price is 1000! -->
      <Mass>0.05</Mass>
      <Flammability>1.5</Flammability>
      <DeteriorationRate>10</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>ResourcesValue</li>
    </thingCategories>
  </ThingDef>

  <!-- Corporate Bond (Continental Petroleum) -->
  <ThingDef ParentName="ResourceBase">
    <defName>HD_ContinentalPetroleumBond</defName>
    <label>Continental Petroleum bond</label>
    <description>An official corporate debt certificate issued by the Continental Petroleum Company, representing a face value of 100 Sthaler. Unlike sovereign government bonds, this corporate security is tied directly to the performance of the oil industry. It serves as highly liquid industrial wealth storage.</description>
    <graphicData>
      <texPath>Item/HD_CorporateBond</texPath> <!-- Re-use the beautifully engraved bond certificate graphic -->
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <stackLimit>25</stackLimit> <!-- Slightly higher stack limit for corporate paper -->
    <healthAffectsPrice>false</healthAffectsPrice>
    <statBases>
      <MaxHitPoints>50</MaxHitPoints>
      <MarketValue>500.0</MarketValue> <!-- Face value: 100 Sthaler * 5 silver = 500 silver -->
      <Mass>0.05</Mass>
      <Flammability>1.5</Flammability>
      <DeteriorationRate>10</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>ResourcesValue</li>
    </thingCategories>
  </ThingDef>

  <ThingCategoryDef>
    <defName>ResourcesValue</defName>
    <label>valuable resources</label>
    <parent>ResourcesRaw</parent>
  </ThingCategoryDef>

</Defs>