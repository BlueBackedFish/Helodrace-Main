<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Temporary Helod backstories for scenario and pawn generation testing. -->
  <BackstoryDef>
    <defName>HD_HelodTempPipelinePup</defName>
    <title>pipeline pup</title>
    <titleShort>pipeline pup</titleShort>
    <baseDesc>[PAWN_nameDef] grew up around frontier pump camps, carrying tools, counting barrels, and learning to sleep through the thump of machinery.</baseDesc>
    <slot>Childhood</slot>
    <spawnCategories>
      <li>HD_Helod</li>
    </spawnCategories>
    <skillGains>
      <Construction>2</Construction>
      <Mining>1</Mining>
      <Crafting>1</Crafting>
    </skillGains>
    <modExtensions>
      <li Class="Helodrace.BackstoryPersonalityDirectionExtension">
        <Assertive>0.35</Assertive>
        <Passive>0.25</Passive>
        <Cooperative>0.65</Cooperative>
        <Independent>0.45</Independent>
      </li>
    </modExtensions>
  </BackstoryDef>

  <BackstoryDef>
    <defName>HD_HelodTempTelegraphRunner</defName>
    <title>telegraph runner</title>
    <titleShort>runner</titleShort>
    <baseDesc>As a young courier, [PAWN_nameDef] carried coded slips between banks, rail camps, and lonely telegraph offices on the edge of settled space.</baseDesc>
    <slot>Childhood</slot>
    <spawnCategories>
      <li>HD_Helod</li>
    </spawnCategories>
    <skillGains>
      <Social>1</Social>
      <Intellectual>2</Intellectual>
      <Shooting>1</Shooting>
    </skillGains>
    <modExtensions>
      <li Class="Helodrace.BackstoryPersonalityDirectionExtension">
        <Assertive>0.45</Assertive>
        <Passive>0.20</Passive>
        <Cooperative>0.75</Cooperative>
        <Independent>0.55</Independent>
      </li>
    </modExtensions>
  </BackstoryDef>

  <BackstoryDef>
    <defName>HD_HelodTempFoundryOrphan</defName>
    <title>foundry orphan</title>
    <titleShort>foundry kid</titleShort>
    <baseDesc>[PAWN_nameDef] was raised by a smoky machine yard where spare hands were expected to sort coal, fetch water, and keep clear of red-hot iron.</baseDesc>
