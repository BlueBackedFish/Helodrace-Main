  </BackstoryDef>

  <BackstoryDef>
    <defName>HD_HelodTempFrontierMechanic</defName>
    <title>frontier mechanic</title>
    <titleShort>mechanic</titleShort>
    <baseDesc>[PAWN_nameDef] kept battered engines, pumps, and line shafts alive with improvised parts and stubborn patience. The frontier rarely offered a second chance for bad repairs.</baseDesc>
    <slot>Adulthood</slot>
    <spawnCategories>
      <li>HD_Helod</li>
    </spawnCategories>
    <skillGains>
