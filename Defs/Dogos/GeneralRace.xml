<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <AlienRace.ThingDef_AlienRace ParentName="HD_PawnBase">
    <defName>Helod</defName>
    <label>Helod</label>
    <description>A noble canine-like humanoid race known for their loyalty, agility, and frontier spirit. Excellent survivors, trackers, and marksmen.</description>
    <inspectorTabs>
      <li>Helodrace.ITab_M6RocketBag</li>
    </inspectorTabs>
    <alienRace>
      <generalSettings>
        <maleGenderProbability>0.0000001</maleGenderProbability>
        <immuneToAge>false</immuneToAge>
        <humanRecipeImport>true</humanRecipeImport>
        <canLayDown>true</canLayDown>
        <maxDamageForSocialfight>6</maxDamageForSocialfight>
        <immuneToXenophobia>false</immuneToXenophobia>
        
        <disallowedTraits>
          <li>
            <defName Degree="-1">SpeedOffset</defName>
          </li>
          <li>
            <defName>CreepyBreathing</defName>
          </li>
          <li>
            <defName>BodyPurist</defName>
          </li>
        </disallowedTraits>

        <alienPartGenerator>
          <atlasScale>4</atlasScale>
          <headTypes>
            <li>HD_HelodHead01</li>
            <li>HD_HelodHead02</li>
          </headTypes>
          <bodyTypes>
            <li>Female</li>
            <!--<li>Thin</li>-->
          </bodyTypes>
          <headOffset>(0.0, 0.11)</headOffset>
          <customDrawSize>(0.8, 0.8)</customDrawSize>
          <customHeadDrawSize>(0.8, 0.8)</customHeadDrawSize>
          <customPortraitDrawSize>(0.8, 0.8)</customPortraitDrawSize>
          
          <colorChannels>
            <li>
              <name>skin</name>
              <first Class="ColorGenerator_Single">
                <color>(1.0, 1.0, 1.0)</color>
              </first>
              <second Class="ColorGenerator_Single">
                <color>(1.0, 1.0, 1.0)</color>
              </second>
            </li>
            <li>
              <name>hair</name>
              <first Class="ColorGenerator_Options">
                <options>
                  <!-- Charcoal Black -->
                  <li>
                    <weight>70</weight>
                    <only>RGBA(92, 92, 92, 255)</only>
                  </li>
                  <!-- Cocoa -->
                  <li>
                    <weight>150</weight>
                    <only>RGBA(181, 132, 102, 255)</only>
                  </li>
                  <!-- Brown -->
                  <li>
                    <weight>150</weight>
                    <only>RGBA(153, 69, 0, 255)</only>
                  </li>
                  <!-- Gold Blonde -->
                  <li>
                    <weight>100</weight>
                    <only>RGBA(221, 150, 0, 255)</only>
                  </li>
                  <!-- White Blonde -->
                  <li>
                    <weight>100</weight>
                    <only>RGBA(242, 214, 153, 255)</only>
                  </li>
                  <!-- Sugar Ash -->
                  <li>
                    <weight>50</weight>
                    <only>RGBA(148, 138, 138, 255)</only>
                  </li>
                  <!-- Gold Rose -->
                  <li>
                    <weight>40</weight>
                    <only>RGBA(181, 135, 89, 255)</only>
                  </li>
                  <!-- Dark Rose -->
                  <li>
                    <weight>30</weight>
                    <only>RGBA(171, 40, 46, 255)</only>
                  </li>
                  <!-- Light Purple -->
                  <li>
                    <weight>40</weight>
                    <only>RGBA(229, 193, 255, 255)</only>
                  </li>
                  <!-- Aqua -->
                  <li>
                    <weight>40</weight>
                    <only>RGBA(0, 206, 255, 255)</only>
                  </li>
                  <!-- White -->
                  <li>
                    <weight>20</weight>
                    <only>RGBA(230, 230, 230, 255)</only>
                  </li>
                </options>
              </first>
              <second Class="ColorGenerator_Single">
                <color>RGBA(0, 0, 0, 0)</color>
              </second>
            </li>
          </colorChannels>

          <bodyAddons>
            <!-- Tail -->
            <li>
              <drawSize>1</drawSize>
              <path>Dogos/Tail/HelodTail</path>
              <conditions>
                <BodyPart>
                  <bodyPart>HD_HelodTail</bodyPart>
                  <bodyPartLabel>tail</bodyPartLabel>
                </BodyPart>
                <Posture>
                  <drawnStanding>true</drawnStanding>
                  <drawnInBed>false</drawnInBed>
                </Posture>
                <RotStage>Fresh,Rotting</RotStage>
              </conditions>
              <inFrontOfBody>false</inFrontOfBody>
              <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
              <colorChannel>hair</colorChannel>
              <defaultOffset>Tail</defaultOffset>
              <shaderType>Cutout</shaderType>
              <offsets>
                <south><offset>(-0.25,0.25)</offset></south>
                <north>
                  <offset>(-0.05,0.36)</offset>
                  <layerOffset>-0.2</layerOffset> <!-- 북쪽을 볼 때 몸 뒤로 숨김 -->
                </north>
                <east><offset>(-0.11,0.18)</offset></east>
              </offsets>
            </li>

            <!-- Left Ear -->
            <li>
              <path>Dogos/EarLeft/Ear1Left</path>
              <conditions>
                <BodyPart>
                  <bodyPart>Ear</bodyPart>
                  <bodyPartLabel>left ear</bodyPartLabel>
                </BodyPart>
                <RotStage>Fresh,Rotting</RotStage>
              </conditions>
              <inFrontOfBody>true</inFrontOfBody>
              <colorChannel>hair</colorChannel>
              <drawSize>1.0</drawSize>
              <angle>0</angle>
              <alignWithHead>true</alignWithHead>
              <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
              <defaultOffset>Tail</defaultOffset>
              <shaderType>CutoutComplex</shaderType>
              <offsets>
                <north>
                  <offset>(-0.11,0.64)</offset>
                  <layerOffset></layerOffset>
                </north>
                <east>
                  <offset>(-0.44,0.44)</offset>
                  <layerOffset>0.004</layerOffset>
                </east>
                <south>
                  <offset>(-0.259,0.457)</offset>
                  <layerOffset>0.004</layerOffset>
                </south>
              </offsets>
            </li>

            <!-- Right Ear -->
            <li>
              <path>Dogos/EarRight/Ear1Right</path>
              <conditions>
                <BodyPart>
                  <bodyPart>Ear</bodyPart>
                  <bodyPartLabel>right ear</bodyPartLabel>
                </BodyPart>
                <RotStage>Fresh,Rotting</RotStage>
              </conditions>
              <inFrontOfBody>true</inFrontOfBody>
              <colorChannel>hair</colorChannel>
              <drawSize>1.0</drawSize>
              <angle>0</angle>
              <alignWithHead>true</alignWithHead>
              <scaleWithPawnDrawsize>true</scaleWithPawnDrawsize>
              <defaultOffset>Tail</defaultOffset>
              <shaderType>CutoutComplex</shaderType>
              <offsets>
                <north>
                  <offset>(0.26,0.64)</offset>
                  <layerOffset></layerOffset>
                </north>
                <east>
                  <offset>(-0.44,0.44)</offset>
                  <layerOffset>0.004</layerOffset>
                </east>
                <south>
                  <offset>(-0.581,0.457)</offset>
                  <layerOffset>0.004</layerOffset>
                </south>
              </offsets>
            </li>
          </bodyAddons>
        </alienPartGenerator>
      </generalSettings>

      <!-- Graphic Paths -->
      <graphicPaths>
        <body>Dogos/Body/</body>
        <skeleton>Things/Pawn/Humanlike/Bodies/Dessicated/Dessicated_Thin</skeleton>
      </graphicPaths>

      <styleSettings>
        <li>
          <key>HairDef</key>
          <value>
            <hasStyle>true</hasStyle>
            <styleTagsOverride>
              <li>HelodHair</li>
            </styleTagsOverride>
          </value>
        </li>
        <li>
          <key>BeardDef</key>
          <value>
            <hasStyle>false</hasStyle>
          </value>
        </li>
        <li>
          <key>TattooDef</key>
          <value>
            <hasStyle>false</hasStyle>
          </value>
        </li>
      </styleSettings>

      <relationSettings>
        <relationChanceModifierChild>1</relationChanceModifierChild>
        <relationChanceModifierExLover>1</relationChanceModifierExLover>
        <relationChanceModifierExSpouse>1</relationChanceModifierExSpouse>
        <relationChanceModifierFiance>1</relationChanceModifierFiance>
        <relationChanceModifierLover>1</relationChanceModifierLover>
        <relationChanceModifierParent>1</relationChanceModifierParent>
        <relationChanceModifierSibling>1</relationChanceModifierSibling>
        <relationChanceModifierSpouse>1</relationChanceModifierSpouse>
      </relationSettings>

      <thoughtSettings>
      </thoughtSettings>

      <raceRestriction>
        <onlyUseRaceRestrictedApparel>true</onlyUseRaceRestrictedApparel>
        <apparelList>
          <li>HD_Apparel_CarvalyUniform</li>
          <li>HD_Apparel_CarvalyHat</li>
          <li>HD_Apparel_CowboyHat</li>
          <li>HD_Apparel_WildWestTopHat</li>
          <li>HD_Apparel_WildWestFemaleCasual</li>
          <li>HD_Apparel_WildWestMaleCasual</li>
          <li>HD_Apparel_WildWestFormalShirt</li>
          <li>HD_Apparel_WildWestFrockCoat</li>
          <li>HD_WildWestLeatherVest</li>
          <li>HD_WildWestMetalVest</li>
          <li>HD_Bugle</li>
          <li>HD_Apparel_GreatWarMedibag</li>
          <li>HD_Apparel_GreatWarGasMaskPouch</li>
          <li>HD_Apparel_GreatWarCBRNPouch</li>
          <li>HD_Apparel_M6RocketBag</li>
          <li>HD_Apparel_GreatWarTrenchArmyInner</li>
          <li>HD_Apparel_GreatWarTrenchArmyOuter</li>
          <li>HD_Apparel_GreatWarM1Helmet</li>
          <li>HD_Apparel_M1MortarBaseplate</li>
          <li>HD_Apparel_M1MortarMount</li>
          <li>HD_Apparel_M1MortarBarrel</li>
          <li>HD_MilitaryTablet</li>
          <li>HD_Apparel_IBTVAssault</li>
        </apparelList>
        <onlyUseRaceRestrictedWeapons>false</onlyUseRaceRestrictedWeapons>
        <blackGeneList MayRequire="Ludeon.RimWorld.Biotech">
          <li MayRequire="Ludeon.RimWorld.Biotech">Furskin</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Hair_BaldOnly</li>
        </blackGeneList>
        <blackEndoCategories MayRequire="Ludeon.RimWorld.Biotech">
          <li MayRequire="Ludeon.RimWorld.Biotech">Melanin</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Headbone</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Head</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Jaw</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Ears</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Nose</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Voice</li>
        </blackEndoCategories>
        <xenotypeList MayRequire="Ludeon.RimWorld.Biotech">
          <li MayRequire="Ludeon.RimWorld.Biotech">HD_MackenzieValleyHelod</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">HD_TexasHelod</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">HD_ArcticHelod</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">HD_EasternHelod</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">HD_MexicanHelod</li>
        </xenotypeList>
        <blackXenotypeList MayRequire="Ludeon.RimWorld.Biotech">
          <li MayRequire="Ludeon.RimWorld.Biotech">Dirtmole</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Genie</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Hussar</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Sanguophage</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Neanderthal</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Pigskin</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Impid</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Waster</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Yttakin</li>
          <li MayRequire="Ludeon.RimWorld.Biotech">Highmate</li>
        </blackXenotypeList>
        <onlyUseRaceRestrictedXenotypes MayRequire="Ludeon.RimWorld.Biotech">true</onlyUseRaceRestrictedXenotypes>
      </raceRestriction>
    </alienRace>

    <statBases>
      <MarketValue>1750</MarketValue>
      <Flammability>1.0</Flammability>
      <MoveSpeed>4.6</MoveSpeed>
      <MentalBreakThreshold>0.35</MentalBreakThreshold>
      <ComfyTemperatureMax>26</ComfyTemperatureMax>
      <ComfyTemperatureMin>8</ComfyTemperatureMin>
      <ImmunityGainSpeed>1.0</ImmunityGainSpeed>
      <CarryingCapacity>75</CarryingCapacity>
      <MeatAmount>50</MeatAmount>
      <LeatherAmount>40</LeatherAmount>
      <Mass>55</Mass>
      <PainShockThreshold>0.80</PainShockThreshold>
      <PsychicSensitivity>1.0</PsychicSensitivity>
      <MeleeDodgeChance>1.1</MeleeDodgeChance>
      <MeleeHitChance>1.0</MeleeHitChance>
      <AimingDelayFactor>1.0</AimingDelayFactor>
      <ShootingAccuracyPawn>1.0</ShootingAccuracyPawn>
    </statBases>

    <tools>
      <li>
        <label>left fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8.2</power>
        <cooldownTime>2.0</cooldownTime>
        <linkedBodyPartsGroup>LeftHand</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>14</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>right fist</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>8.2</power>
        <cooldownTime>2.0</cooldownTime>
        <linkedBodyPartsGroup>RightHand</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Stun</def>
              <amount>14</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
      </li>
      <li>
        <label>teeth</label>
        <capacities>
          <li>Bite</li>
        </capacities>
        <power>12.0</power>
        <cooldownTime>2.6</cooldownTime>
        <linkedBodyPartsGroup>Teeth</linkedBodyPartsGroup>
        <surpriseAttack>
          <extraMeleeDamages>
            <li>
              <def>Bite</def>
              <amount>18</amount>
            </li>
          </extraMeleeDamages>
        </surpriseAttack>
        <chanceFactor>0.4</chanceFactor>
      </li>
    </tools>

    <race>
      <thinkTreeMain>Humanlike</thinkTreeMain>
      <thinkTreeConstant>HumanlikeConstant</thinkTreeConstant>
      <intelligence>Humanlike</intelligence>
      <makesFootprints>true</makesFootprints>
      <lifeExpectancy>80</lifeExpectancy>
      <leatherDef>Leather_Human</leatherDef>
      <nameCategory>HumanStandard</nameCategory>
      <hasGenders>true</hasGenders>
      <body>HD_HelodBody</body>
      <renderTree>Humanlike</renderTree>
      <canBecomeShambler>false</canBecomeShambler>
      <baseBodySize>1</baseBodySize>
      <baseHealthScale>1.0</baseHealthScale>
      <foodType>OmnivoreHuman</foodType>
      <gestationPeriodDays>30</gestationPeriodDays>
      <litterSizeCurve>
        <points>
          <li>(0.5, 0)</li>
          <li>(1, 1.0)</li>
          <li>(2, 0.2)</li>
          <li>(3, 0.0)</li>
        </points>
      </litterSizeCurve>
      <lifeStageAges>
        <li>
          <def>HumanlikeBaby</def>
          <minAge>0</minAge>
        </li>
        <li>
          <def>HumanlikeChild</def>
          <minAge>3</minAge>
        </li>
        <li>
          <def>HumanlikeTeenager</def>
          <minAge>13</minAge>
        </li>
        <li>
          <def>HumanlikeAdult</def>
          <minAge>18</minAge>
        </li>
      </lifeStageAges>
      <soundMeleeHitPawn>Pawn_Melee_Punch_HitPawn</soundMeleeHitPawn>
      <soundMeleeHitBuilding>Pawn_Melee_Punch_HitBuilding</soundMeleeHitBuilding>
      <soundMeleeMiss>Pawn_Melee_Punch_Miss</soundMeleeMiss>
      <soundMeleeDodge>Pawn_Melee_Dodge</soundMeleeDodge>
      <specialShadowData>
        <volume>(0.3, 0.8, 0.4)</volume>
        <offset>(0,0,-0.3)</offset>
      </specialShadowData>
      <ageGenerationCurve>
        <points>
          <li>(14,0)</li>
          <li>(16,100)</li>
          <li>(50,100)</li>
          <li>(60,30)</li>
          <li>(70,18)</li>
          <li>(80,0)</li>
        </points>
      </ageGenerationCurve>
      <hediffGiverSets>
        <li>OrganicStandard</li>
        <li>Human</li>
      </hediffGiverSets>
    </race>
  </AlienRace.ThingDef_AlienRace>
</Defs>
