<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <HediffDef>
    <defName>HD_BTXHigh</defName>
    <label>BTX stabilization</label>
    <labelNoun>BTX stabilization</labelNoun>
    <description>BTX compounds are circulating through the bloodstream, temporarily stabilizing Helod biochemical pathways.</description>
    <hediffClass>Hediff_High</hediffClass>
    <defaultLabelColor>(0.35,0.85,0.95)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-1.0</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li />
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HD_BTXToxicity</defName>
    <label>BTX poisoning</label>
    <labelNoun>BTX poisoning</labelNoun>
    <description>BTX compounds are irritating and poisoning this body. Helod biochemistry can metabolize these compounds, but other species suffer petroleum-like toxic effects.</description>
    <hediffClass>Helodrace.Hediff_BTXToxicity</hediffClass>
    <defaultLabelColor>(0.8,0.85,0.45)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <label>mild</label>
        <painOffset>0.08</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.05</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.05</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.45</minSeverity>
        <label>sick</label>
        <painOffset>0.18</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.12</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.08</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.75</minSeverity>
        <label>severe</label>
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.35</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.20</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HD_BTXDeficiency</defName>
    <label>BTX deficiency</label>
    <labelNoun>BTX deficiency</labelNoun>
    <description>This Helod's engineered metabolism is running out of BTX compounds. If the deficiency reaches total collapse, death follows.</description>
    <defaultLabelColor>(0.9,0.35,0.25)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <lethalSeverity>1.0</lethalSeverity>
    <isBad>true</isBad>
    <stages>
      <li>
        <label>minor</label>
        <painOffset>0.05</painOffset>
      </li>
      <li>
        <minSeverity>0.25</minSeverity>
        <label>deficiency</label>
        <painOffset>0.12</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.08</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.08</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.60</minSeverity>
        <label>critical</label>
        <painOffset>0.25</painOffset>
        <lifeThreatening>true</lifeThreatening>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.20</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <HediffDef>
    <defName>HD_PlainDogChewHigh</defName>
    <label>chewing plain dog chew</label>
    <labelNoun>plain dog chew effect</labelNoun>
    <description>Slow-release BTX compounds from a plain dog chew are circulating through the body, producing a mild stabilizing effect.</description>
    <hediffClass>Hediff_High</hediffClass>
    <defaultLabelColor>(0.55,0.75,0.65)</defaultLabelColor>
    <scenarioCanAdd>true</scenarioCanAdd>
    <maxSeverity>1.0</maxSeverity>
    <isBad>false</isBad>
    <comps>
      <li Class="HediffCompProperties_SeverityPerDay">
        <severityPerDay>-0.25</severityPerDay>
        <showHoursToRecover>true</showHoursToRecover>
      </li>
    </comps>
    <stages>
      <li>
        <capMods>
          <li>
            <capacity>Manipulation</capacity>
            <offset>0.04</offset>
          </li>
          <li>
            <capacity>Consciousness</capacity>
            <offset>0.03</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>

  <ChemicalDef>
    <defName>BTX</defName>
    <label>BTX</label>
    <canBeAddicted>false</canBeAddicted>
    <generateAddictionGenes>false</generateAddictionGenes>
    <canBinge>false</canBinge>
    <geneOverdoseChanceFactorResist>0.5</geneOverdoseChanceFactorResist>
    <geneOverdoseChanceFactorImmune>0</geneOverdoseChanceFactorImmune>
  </ChemicalDef>

  <NeedDef>
    <defName>HD_BTXNeed</defName>
    <needClass>Helodrace.Need_BTX</needClass>
    <label>BTX</label>
    <description>Helod metabolism requires periodic BTX intake. If this need empties, BTX deficiency slowly worsens until it becomes fatal.</description>
    <minIntelligence>Humanlike</minIntelligence>
    <baseLevel>1.0</baseLevel>
    <major>true</major>
    <fallPerDay>0.333</fallPerDay>
    <listPriority>46</listPriority>
  </NeedDef>

  <ThoughtDef>
    <defName>HD_BTXNeedLow</defName>
    <workerClass>Helodrace.ThoughtWorker_BTXNeed</workerClass>
    <validWhileDespawned>true</validWhileDespawned>
    <stages>
      <li>
        <label>BTX running low</label>
        <description>My BTX reserves are running low. I can feel my engineered metabolism beginning to slip.</description>
        <baseMoodEffect>-3</baseMoodEffect>
      </li>
      <li>
        <label>BTX critically low</label>
        <description>My BTX reserves are critically low. Every system in my body feels unstable.</description>
        <baseMoodEffect>-8</baseMoodEffect>
      </li>
      <li>
        <label>BTX depleted</label>
        <description>My BTX reserves are depleted. My body is starting to fail.</description>
        <baseMoodEffect>-14</baseMoodEffect>
      </li>
    </stages>
  </ThoughtDef>

</Defs>
