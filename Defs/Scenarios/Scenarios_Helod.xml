<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Scenario: 4-Pawn Start (Helod Gilded Pioneers) based on Biotech and Wild West mechanics -->
  <ScenarioDef ParentName="ScenarioBase">
    <defName>HD_Scenario_HelodFourPawns</defName>
    <label>Helod Gilded Pioneers</label>
    <description>Four Helod pioneers venture deep into the harsh, untamed frontier to establish an industrial outpost. Equipped with high starting funds of Sthaler banknotes, raw pemmican rations, three Graylock M1861 rifled muskets, and a steel knife (iron dagger), they are ready to seize control of local petroleum and build their financial empire.</description>
    <scenario>
      <summary>Four Helod settlers starting with Sthaler money, pemmican, three M1861 rifles, and a steel knife.</summary>
      <playerFaction>
        <def>PlayerFaction</def>
        <factionDef>HD_HelodPlayerColony</factionDef>
      </playerFaction>
      <parts Inherit="False">
        <!-- Arrival Method (Standard Vanilla DropPods arrival) -->
        <li Class="ScenPart_PlayerPawnsArriveMethod">
          <def>PlayerPawnsArriveMethod</def>
          <visible>false</visible>
          <method>Standing</method>
        </li>

        <!-- Helod scenario balance: electricity research takes three times longer. -->
        <li Class="Helodrace.ScenPart_ResearchCostFactor">
          <def>HD_ResearchCostFactor</def>
          <project>Electricity</project>
          <factor>3</factor>
        </li>

        <!-- Config page (Advanced Biotech Xenotypes configuration) -->
        <li Class="ScenPart_ConfigPage_ConfigureStartingPawns_Xenotypes">
          <def>ConfigurePawnsXenotypes</def>
          <pawnChoiceCount>4</pawnChoiceCount>
          <customSummary>네 명의 다양한 헤로드 아종 개척자로 시작합니다.</customSummary>
          <overrideKinds>
            <li>
              <xenotype>HD_MackenzieValleyHelod</xenotype>
              <pawnKind>HD_WW_HelodColonist</pawnKind>
            </li>
            <li>
              <xenotype>HD_TexasHelod</xenotype>
              <pawnKind>HD_WW_HelodColonist</pawnKind>
            </li>
            <li>
              <xenotype>HD_ArcticHelod</xenotype>
              <pawnKind>HD_WW_HelodColonist</pawnKind>
            </li>
            <li>
              <xenotype>HD_EasternHelod</xenotype>
              <pawnKind>HD_WW_HelodColonist</pawnKind>
            </li>
          </overrideKinds>
          <xenotypeCounts>
            <li>
              <xenotype>HD_MackenzieValleyHelod</xenotype>
              <count>1</count>
              <requiredAtStart>true</requiredAtStart>
            </li>
            <li>
              <xenotype>HD_TexasHelod</xenotype>
              <count>1</count>
              <requiredAtStart>true</requiredAtStart>
            </li>
            <li>
              <xenotype>HD_ArcticHelod</xenotype>
              <count>1</count>
              <requiredAtStart>true</requiredAtStart>
            </li>
            <li>
              <xenotype>HD_EasternHelod</xenotype>
              <count>1</count>
              <requiredAtStart>true</requiredAtStart>
            </li>
          </xenotypeCounts>
        </li>

        <!-- Starting Items -->
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>HD_Money</thingDef>
          <count>150</count> <!-- 150 Sthaler Banknotes -->
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>HD_Gun_SprMOne_Weapon</thingDef>
          <count>3</count> <!-- 3 Graylock M1861 Rifled Muskets -->
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>MeleeWeapon_Knife</thingDef>
          <stuff>Steel</stuff>
          <count>1</count> <!-- 1 Steel Dagger/Knife -->
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>Pemmican</thingDef>
          <count>400</count> <!-- Pemmican Survival Rations -->
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>HD_Naphtha</thingDef>
          <count>40</count> <!-- Initial naphtha supply for Helod BTX dependency -->
        </li>
        <li Class="ScenPart_StartingThing_Defined">
          <def>StartingThing_Defined</def>
          <thingDef>WoodLog</thingDef>
          <count>300</count> <!-- Starting Wood -->
        </li>

        <!-- Scatter on Map (Standard starter scattering) -->
        <li Class="ScenPart_ScatterThingsNearPlayerStart">
          <def>ScatterThingsNearPlayerStart</def>
          <thingDef>Steel</thingDef>
          <count>450</count>
        </li>
        <li Class="ScenPart_ScatterThingsNearPlayerStart">
          <def>ScatterThingsNearPlayerStart</def>
          <thingDef>MedicineIndustrial</thingDef>
          <count>30</count>
        </li>
      </parts>
    </scenario>
  </ScenarioDef>

</Defs>
