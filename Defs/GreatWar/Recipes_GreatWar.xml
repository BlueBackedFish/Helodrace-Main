  <RecipeDef>
    <defName>HD_MakeFLAM</defName>
    <label>make FLAM x20</label>
    <description>Can a large batch of finely processed meat into compact tins of FLAM.</description>
    <jobString>Making FLAM.</jobString>
    <workAmount>1800</workAmount>
    <workSpeedStat>CookSpeed</workSpeedStat>
    <workSkill>Cooking</workSkill>
    <requiredGiverWorkType>Cooking</requiredGiverWorkType>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <ingredientValueGetterClass>Helodrace.IngredientValueGetter_FLAM</ingredientValueGetterClass>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>1</count>
      </li>
      <li>
        <filter>
          <categories>
            <li>MeatRaw</li>
          </categories>
        </filter>
        <count>15</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
      </thingDefs>
      <categories>
        <li>MeatRaw</li>
      </categories>
    </fixedIngredientFilter>
    <products>
      <HD_FLAM>20</HD_FLAM>
    </products>
    <recipeUsers>
      <li>ElectricStove</li>
      <li>FueledStove</li>
    </recipeUsers>
    <skillRequirements>
      <Cooking>6</Cooking>
    </skillRequirements>
  </RecipeDef>

