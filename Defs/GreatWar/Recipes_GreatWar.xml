<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <RecipeDef>
    <defName>HD_MakeHardtackBulk</defName>
    <label>make hardtack x32</label>
    <description>Bake a bulk batch of long-lasting hardtack from vegetarian ingredients.</description>
    <jobString>Making hardtack.</jobString>
    <workAmount>2400</workAmount>
    <workSpeedStat>CookSpeed</workSpeedStat>
    <workSkill>Cooking</workSkill>
    <requiredGiverWorkType>Cooking</requiredGiverWorkType>
    <effectWorking>Cook</effectWorking>
    <soundWorking>Recipe_CookMeal</soundWorking>
    <ingredients>
      <li>
        <filter>
          <categories>
            <li>PlantFoodRaw</li>
          </categories>
          <disallowedThingDefs>
            <li>HD_Hardtack</li>
          </disallowedThingDefs>
        </filter>
        <count>3.2</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <categories>
        <li>PlantFoodRaw</li>
      </categories>
      <disallowedThingDefs>
        <li>HD_Hardtack</li>
      </disallowedThingDefs>
    </fixedIngredientFilter>
    <products>
      <HD_Hardtack>32</HD_Hardtack>
    </products>
    <recipeUsers>
      <li>ElectricStove</li>
      <li>FueledStove</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef>
    <defName>HD_Make3InchMortarShellHE</defName>
    <label>make 3-inch mortar HE shell</label>
    <description>Assemble a high-explosive shell for the 3-inch Hawkins mortar.</description>
    <jobString>Making 3-inch mortar HE shell.</jobString>
    <workAmount>1600</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <requiredGiverWorkType>Crafting</requiredGiverWorkType>
    <effectWorking>Sculpt</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <researchPrerequisite>HelodHighExplosive</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>15</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </filter>
        <count>10</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Chemfuel</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <HD_3InchMortarShell_HE>1</HD_3InchMortarShell_HE>
    </products>
    <recipeUsers>
      <li>HD_BasicWorkbench</li>
    </recipeUsers>
    <skillRequirements>
      <Crafting>5</Crafting>
    </skillRequirements>
  </RecipeDef>

  <RecipeDef>
    <defName>HD_Make3InchMortarShellCG</defName>
    <label>make 3-inch mortar photochlorogen shell</label>
    <description>Assemble a compact photochlorogen shell for the 3-inch Hawkins mortar.</description>
    <jobString>Making 3-inch mortar photochlorogen shell.</jobString>
    <workAmount>1800</workAmount>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <workSkill>Crafting</workSkill>
    <requiredGiverWorkType>Crafting</requiredGiverWorkType>
    <effectWorking>Sculpt</effectWorking>
    <soundWorking>Recipe_Machining</soundWorking>
    <researchPrerequisite>HelodChokingAgent</researchPrerequisite>
    <ingredients>
      <li>
        <filter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </filter>
        <count>12</count>
      </li>
      <li>
        <filter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </filter>
        <count>15</count>
      </li>
    </ingredients>
    <fixedIngredientFilter>
      <thingDefs>
        <li>Steel</li>
        <li>Chemfuel</li>
      </thingDefs>
    </fixedIngredientFilter>
    <products>
      <HD_3InchMortarShell_CG>1</HD_3InchMortarShell_CG>
    </products>
    <recipeUsers>
      <li>HD_BasicWorkbench</li>
    </recipeUsers>
    <skillRequirements>
      <Crafting>5</Crafting>
    </skillRequirements>
  </RecipeDef>

</Defs>
