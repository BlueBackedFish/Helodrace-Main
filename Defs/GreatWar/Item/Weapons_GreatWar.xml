  <ThingDef ParentName="BaseMakeableGun">
    <defName>HD_Gun_M1903Pedersen_Weapon</defName>
    <weaponTags>
      <li>HD_Rifle</li>
      <li>Rifle</li>
    </weaponTags>
    <label>Springfield M1903 Pedersen device (Helodrace)</label>
    <description>A Springfield M1903 fitted with a Pedersen device, trading full-power rifle cartridges for fast semi-automatic fire with lighter ammunition. Adapted for Helodrace use.</description>
    <graphicData>
      <texPath>Weapon/GreatWar/HD_M1903Pedersen</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.1, 1.1)</drawSize>
    </graphicData>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>Interact_Rifle</soundInteract>
    <statBases>
      <WorkToMake>42000</WorkToMake>
      <Mass>4.0</Mass>
      <AccuracyTouch>0.60</AccuracyTouch>
      <AccuracyShort>0.75</AccuracyShort>
      <AccuracyMedium>0.78</AccuracyMedium>
      <AccuracyLong>0.55</AccuracyLong>
      <RangedWeapon_Cooldown>1.0</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>85</Steel>
