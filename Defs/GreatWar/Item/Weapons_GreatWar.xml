  <!-- ==================== Weapons ==================== -->

  <ThingDef ParentName="BaseMakeableGun">
    <defName>HD_Gun_KragJorgensen_Weapon</defName>
    <weaponTags>
      <li>HD_Rifle</li>
      <li>HD_BoltActionRifle</li>
      <li>Rifle</li>
    </weaponTags>
    <label>Krag-Jorgensen (Helodrace)</label>
    <description>A bolt-action rifle with a unique side-loading magazine. Famous for its smooth action. Adapted for Helodrace use.</description>
    <graphicData>
      <texPath>Weapon/GreatWar/KragJorgensen</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.1, 1.1)</drawSize>
    </graphicData>
    <equippedAngleOffset>45</equippedAngleOffset>
    <soundInteract>Interact_Rifle</soundInteract>
    <statBases>
      <WorkToMake>35000</WorkToMake>
      <Mass>4.1</Mass>
      <AccuracyTouch>0.55</AccuracyTouch>
      <AccuracyShort>0.70</AccuracyShort>
      <AccuracyMedium>0.85</AccuracyMedium>
      <AccuracyLong>0.80</AccuracyLong>
      <RangedWeapon_Cooldown>2.3</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>75</Steel>
      <ComponentIndustrial>4</ComponentIndustrial>
    </costList>
    <comps>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
      <li Class="Helodrace.CompProperties_SharpshooterWeapon">
        <altVerbIndex>1</altVerbIndex>
        <altCooldownMultiplier>1.0</altCooldownMultiplier>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_Bullet_KragJorgensen_Proj</defaultProjectile>
        <warmupTime>1.5</warmupTime>
        <range>36.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>Shot_BoltActionRifle</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>12</muzzleFlashScale>
      </li>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>false</hasStandardCommand>
        <defaultProjectile>HD_Bullet_KragJorgensen_Proj</defaultProjectile>
        <warmupTime>0.4</warmupTime>
        <range>19.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>Shot_BoltActionRifle</soundCast>
        <soundCastTail>GunTail_Heavy</soundCastTail>
        <muzzleFlashScale>12</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>stock</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

