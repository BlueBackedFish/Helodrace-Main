  <!-- ==================== Weapons ==================== -->

  <ThingDef ParentName="BaseMakeableGun">
    <defName>HD_Gun_M1911_Weapon</defName>
    <weaponTags>
      <li>HD_GreatWarPistol</li>
    </weaponTags>
    <label>Ironfang M1911</label>
    <description>Hartmann's masterpiece, a gun handed down from grandfathers, and a gun like the heart of Vessenica. A rugged semi-automatic service pistol with a heavy cartridge and fast follow-up shots.</description>
    <graphicData>
      <texPath>Weapon/GreatWar/HD_m1911</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.7,0.7)</drawSize>
    </graphicData>
    <soundInteract>Interact_Revolver</soundInteract>
    <statBases>
      <WorkToMake>18000</WorkToMake>
      <Mass>1.11</Mass>
      <AccuracyTouch>0.88</AccuracyTouch>
      <AccuracyShort>0.78</AccuracyShort>
      <AccuracyMedium>0.48</AccuracyMedium>
      <AccuracyLong>0.25</AccuracyLong>
      <RangedWeapon_Cooldown>1.0</RangedWeapon_Cooldown>
    </statBases>
    <costList>
      <Steel>32</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
      <HD_LowQualityMagazineSpring>1</HD_LowQualityMagazineSpring>
    </costList>
    <recipeMaker Inherit="False" IsNull="True" />

    <comps>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
      <li Class="Helodrace.CompProperties_SharpshooterWeapon">
        <altVerbIndex>1</altVerbIndex>
        <altCooldownMultiplier>1.0</altCooldownMultiplier>
        <altAccuracyMultiplier>1.0</altAccuracyMultiplier>
        <altModeLabelKey>HD_SharpshooterMode_DoubleTap</altModeLabelKey>
        <modeDescriptionKey>HD_SharpshooterMode_DoubleTap_Desc</modeDescriptionKey>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_Bullet_M1911_Proj</defaultProjectile>
        <warmupTime>0.25</warmupTime>
        <range>20.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>Shot_Autopistol</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>false</hasStandardCommand>
        <defaultProjectile>HD_Bullet_M1911_Proj</defaultProjectile>
        <warmupTime>0.1</warmupTime>
        <range>10.9</range>
        <burstShotCount>2</burstShotCount>
        <ticksBetweenBurstShots>6</ticksBetweenBurstShots>
        <soundCast>Shot_Autopistol</soundCast>
        <soundCastTail>GunTail_Light</soundCastTail>
        <muzzleFlashScale>9</muzzleFlashScale>
      </li>
    </verbs>
    <tools>
      <li>
        <label>grip</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>9</power>
        <cooldownTime>2</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="BaseWeaponTurret">
