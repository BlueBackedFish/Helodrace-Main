    <comps>
      <li Class="CompProperties_ChangeableProjectile" />
    </comps>
    <building>
      <fixedStorageSettings>
        <filter>
          <thingDefs>
            <li>HD_3InchMortarShell_HE</li>
            <li>HD_3InchMortarShell_CG</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <filter>
          <thingDefs>
            <li>HD_3InchMortarShell_HE</li>
            <li>HD_3InchMortarShell_CG</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
    </building>
