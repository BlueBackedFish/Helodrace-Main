<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef>
    <defName>HD_Hardtack</defName>
    <label>hardtack</label>
    <description>A dense, dry ration baked from preserved vegetarian ingredients. It keeps indefinitely, can be cooked in bulk, and is hard enough to throw in desperation.</description>
    <thingClass>ThingWithComps</thingClass>
    <category>Item</category>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <graphicData>
      <texPath>Item/HD_Hardtack</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <useHitPoints>true</useHitPoints>
    <selectable>true</selectable>
    <altitudeLayer>Item</altitudeLayer>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <equipmentType>Primary</equipmentType>
    <weaponTags>
      <li>NeolithicRangedBasic</li>
    </weaponTags>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>2.0</MarketValue>
      <Mass>0.08</Mass>
      <Flammability>0.8</Flammability>
      <DeteriorationRate>1</DeteriorationRate>
      <Nutrition>0.15</Nutrition>
      <AccuracyTouch>0.55</AccuracyTouch>
      <AccuracyShort>0.45</AccuracyShort>
      <AccuracyMedium>0.20</AccuracyMedium>
      <AccuracyLong>0.05</AccuracyLong>
      <RangedWeapon_Cooldown>1.4</RangedWeapon_Cooldown>
    </statBases>
    <thingCategories>
      <li>FoodMeals</li>
      <li>PlantFoodRaw</li>
    </thingCategories>
    <ingestible>
      <preferability>MealSimple</preferability>
      <foodType>VegetableOrFruit, Processed, Meal</foodType>
      <baseIngestTicks>240</baseIngestTicks>
      <chairSearchRadius>0</chairSearchRadius>
      <ingestSound>Ingest_Bite</ingestSound>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <maxNumToIngestAtOnce>6</maxNumToIngestAtOnce>
    </ingestible>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_Hardtack_Proj</defaultProjectile>
        <warmupTime>0.6</warmupTime>
        <range>11.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>ThrowGrenade</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>hardtack</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>1.4</cooldownTime>
      </li>
    </tools>
  </ThingDef>

  <ThingDef ParentName="ApparelBase">
    <defName>HD_Apparel_GreatWarMedibag</defName>
    <label>medic bag</label>
    <description>A shoulder-slung field medic bag packed with simple herbal remedies and bandaging supplies. It has no special function yet.</description>
    <graphicData>
      <texPath>Item/HD_GreatWarMedibag_item</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <shaderType>Cutout</shaderType>
      <color>(255,255,255)</color>
    </graphicData>
    <statBases>
      <MaxHitPoints>100</MaxHitPoints>
      <WorkToMake>1400</WorkToMake>
      <Mass>1.2</Mass>
      <MarketValue>45</MarketValue>
      <Flammability>0.8</Flammability>
      <EquipDelay>1.0</EquipDelay>
    </statBases>
    <thingCategories>
      <li>Apparel</li>
    </thingCategories>
    <apparel>
      <bodyPartGroups>
        <li>Shoulders</li>
      </bodyPartGroups>
      <wornGraphicPath>Dogos/Appearel/HD_GreatWarMedibag</wornGraphicPath>
      <useWornGraphicMask>false</useWornGraphicMask>
      <parentTagDef>ApparelBody</parentTagDef>
      <drawData>
        <defaultData>
          <layer>110</layer>
        </defaultData>
      </drawData>
      <layers>
        <li>Belt</li>
      </layers>
      <tags>
        <li>HD_Apparel</li>
      </tags>
      <defaultOutfitTags>
        <li>Worker</li>
        <li>Soldier</li>
      </defaultOutfitTags>
    </apparel>
    <comps>
      <li Class="Helodrace.CompProperties_Medibag">
        <medicineDef>MedicineHerbal</medicineDef>
        <plasmaTransfusionHediff>HD_PlasmaTransfusion</plasmaTransfusionHediff>
        <maxStoredMedicine>5</maxStoredMedicine>
        <hemostasisMedicineCost>1</hemostasisMedicineCost>
        <plasmaMedicineCost>1</plasmaMedicineCost>
        <hemostasisPartCount>4</hemostasisPartCount>
        <hemostasisQuality>0.35</hemostasisQuality>
        <hemostasisMaxQuality>0.60</hemostasisMaxQuality>
        <bloodLossReduction>0.20</bloodLossReduction>
        <treatmentTicks>180</treatmentTicks>
        <excludedHemostasisParts>
          <li>Brain</li>
          <li>Heart</li>
          <li>Lung</li>
          <li>Liver</li>
        </excludedHemostasisParts>
      </li>
    </comps>
    <recipeMaker>
      <recipeUsers>
        <li>ElectricTailoringBench</li>
        <li>HandTailoringBench</li>
      </recipeUsers>
    </recipeMaker>
    <stuffCategories>
      <li>Fabric</li>
      <li>Leathery</li>
    </stuffCategories>
    <costStuffCount>25</costStuffCount>
    <costList>
      <MedicineHerbal>5</MedicineHerbal>
    </costList>
  </ThingDef>

