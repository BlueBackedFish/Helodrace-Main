  <ThingDef>
    <defName>HD_Hardtack</defName>
    <label>hardtack</label>
    <description>A dense, dry ration baked from preserved vegetarian ingredients. It keeps indefinitely, can be cooked in bulk, and is hard enough to throw in desperation.</description>
    <thingClass>ThingWithComps</thingClass>
    <category>Item</category>
    <resourceReadoutPriority>Middle</resourceReadoutPriority>
    <graphicData>
      <texPath>Item/HD_Hardtack</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Standard_Drop</soundInteract>
    <soundDrop>Standard_Drop</soundDrop>
    <useHitPoints>true</useHitPoints>
    <selectable>true</selectable>
    <altitudeLayer>Item</altitudeLayer>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <equipmentType>Primary</equipmentType>
    <weaponTags>
      <li>NeolithicRangedBasic</li>
    </weaponTags>
    <statBases>
      <MaxHitPoints>60</MaxHitPoints>
      <MarketValue>2.0</MarketValue>
      <Mass>0.08</Mass>
      <Flammability>0.8</Flammability>
      <DeteriorationRate>1</DeteriorationRate>
      <Nutrition>0.15</Nutrition>
      <AccuracyTouch>0.55</AccuracyTouch>
      <AccuracyShort>0.45</AccuracyShort>
      <AccuracyMedium>0.20</AccuracyMedium>
      <AccuracyLong>0.05</AccuracyLong>
      <RangedWeapon_Cooldown>1.4</RangedWeapon_Cooldown>
    </statBases>
    <thingCategories>
      <li>FoodMeals</li>
      <li>PlantFoodRaw</li>
    </thingCategories>
    <ingestible>
      <preferability>MealSimple</preferability>
      <foodType>VegetableOrFruit, Processed, Meal</foodType>
      <baseIngestTicks>240</baseIngestTicks>
      <chairSearchRadius>0</chairSearchRadius>
      <ingestSound>Ingest_Bite</ingestSound>
      <ingestHoldUsesTable>false</ingestHoldUsesTable>
      <maxNumToIngestAtOnce>6</maxNumToIngestAtOnce>
    </ingestible>
    <comps>
      <li Class="CompProperties_Forbiddable"/>
      <li>
        <compClass>CompEquippable</compClass>
      </li>
    </comps>
    <verbs>
      <li>
        <verbClass>Verb_Shoot</verbClass>
        <hasStandardCommand>true</hasStandardCommand>
        <defaultProjectile>HD_Hardtack_Proj</defaultProjectile>
        <warmupTime>0.6</warmupTime>
        <range>11.9</range>
        <burstShotCount>1</burstShotCount>
        <soundCast>ThrowGrenade</soundCast>
      </li>
    </verbs>
    <tools>
      <li>
        <label>hardtack</label>
        <capacities>
          <li>Blunt</li>
        </capacities>
        <power>4</power>
        <cooldownTime>1.4</cooldownTime>
      </li>
    </tools>
  </ThingDef>

