<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="BuildingBase">
    <defName>HD_Building_M1917HMG</defName>
    <label>M1917 heavy machine gun</label>
    <description>A tripod-mounted, water-cooled heavy machine gun with a 250-round belt. It must be directly operated by a pawn.</description>
    <thingClass>Building_TurretGun</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <drawHighlight>true</drawHighlight>
    <drawHighlightOnlyForHostile>true</drawHighlightOnlyForHostile>
    <graphicData>
      <texPath>Building/Security/HD_Tripod1</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.6,1.6)</drawSize>
      <shadowData>
        <volume>(0.8,0.25,0.8)</volume>
      </shadowData>
    </graphicData>
    <uiIconPath>Building/Security/HD_m1917HMGUI</uiIconPath>
    <altitudeLayer>Building</altitudeLayer>
    <tickerType>Normal</tickerType>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.25</fillPercent>
    <size>(1,1)</size>
    <hasInteractionCell>true</hasInteractionCell>
    <interactionCellOffset>(0,0,-1)</interactionCellOffset>
    <rotatable>true</rotatable>
    <designationCategory>HD_HelodTechnology_Build</designationCategory>
    <uiOrder>2550</uiOrder>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
    <researchPrerequisites>
      <li>HelodBasicMachineGun</li>
    </researchPrerequisites>
    <statBases>
      <MaxHitPoints>180</MaxHitPoints>
      <WorkToBuild>1800</WorkToBuild>
      <Flammability>0.4</Flammability>
      <Mass>48</Mass>
      <ShootingAccuracyTurret>0.90</ShootingAccuracyTurret>
    </statBases>
    <costList>
      <HD_WildWestBarrel>1</HD_WildWestBarrel>
      <HD_GeneralMachinePart>10</HD_GeneralMachinePart>
      <HD_CarbonSteel>95</HD_CarbonSteel>
      <HD_PressComponent>6</HD_PressComponent>
      <HD_UniformRolledSteelPlate>1</HD_UniformRolledSteelPlate>
    </costList>
    <building>
      <turretGunDef>HD_Gun_M1917HMG_TurretGun</turretGunDef>
      <turretBurstWarmupTime>1.2</turretBurstWarmupTime>
      <turretBurstCooldownTime>0.1</turretBurstCooldownTime>
    </building>
    <placeWorkers>
      <li>PlaceWorker_TurretTop</li>
      <li>Helodrace.PlaceWorker_ShowExtendedTurretRadius</li>
    </placeWorkers>
    <comps>
      <li Class="CompProperties_Refuelable">
        <fuelLabel>M1917 ammunition</fuelLabel>
        <fuelGizmoLabel>Ammunition</fuelGizmoLabel>
        <outOfFuelMessage>Needs ammunition</outOfFuelMessage>
        <fuelFilter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </fuelFilter>
        <fuelCapacity>250</fuelCapacity>
        <initialFuelPercent>1</initialFuelPercent>
        <autoRefuelPercent>0.25</autoRefuelPercent>
        <showFuelGizmo>true</showFuelGizmo>
        <minimumFueledThreshold>1</minimumFueledThreshold>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
      </li>
      <li Class="CompProperties_Mannable">
        <manWorkType>Violent</manWorkType>
      </li>
      <li Class="CompProperties_Forbiddable"/>
    </comps>
  </ThingDef>

