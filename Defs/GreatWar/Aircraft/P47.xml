<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="HD_AircraftBase">
    <defName>HD_Aircraft_P47</defName>
    <label>P-47 Thunderbolt</label>
    <description>A rugged single-seat fighter-bomber armed with eight fixed M2 .50 caliber machine guns. Its powerful engine, heavy armor, and three external hardpoints make it exceptionally effective in ground-attack missions.</description>
    <size>(5,5)</size>
    <graphicData>
      <texPath>Aerocraft/P-47/HD_P47</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(45,45)</drawSize>
    </graphicData>
    <uiIconPath>Aerocraft/P-47/HD_P47</uiIconPath>
    <statBases>
      <MaxHitPoints>850</MaxHitPoints>
      <MarketValue>7200</MarketValue>
      <Mass>4536</Mass>
      <Flammability>0.45</Flammability>
    </statBases>
    <modExtensions Inherit="False">
      <li Class="Helodrace.Aircraft.AircraftDefExtension">
        <cruiseSpeed>0.58</cruiseSpeed>
        <turnRate>1.2</turnRate>
        <takeoffTicks>120</takeoffTicks>
        <takeoffDistance>20</takeoffDistance>
        <landingDistance>24</landingDistance>
        <arrivalRadius>1.5</arrivalRadius>
        <defaultLoiterRadius>14</defaultLoiterRadius>
        <airborneDrawScale>1.3</airborneDrawScale>
        <drawShadow>true</drawShadow>
        <cruiseAltitude>30</cruiseAltitude>
        <maxLandingTurnAngle>55</maxLandingTurnAngle>
        <worldFuelPerTile>3</worldFuelPerTile>
        <worldRange>100</worldRange>
        <worldFlightDurationTicks>4000</worldFlightDurationTicks>
      </li>
    </modExtensions>
    <comps Inherit="False">
      <li Class="CompProperties_Refuelable">
        <fuelCapacity>305</fuelCapacity>
        <fuelConsumptionRate>0.0011</fuelConsumptionRate>
        <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
        <initialFuelPercent>0</initialFuelPercent>
        <initialConfigurableTargetFuelLevel>305</initialConfigurableTargetFuelLevel>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <showFuelGizmo>true</showFuelGizmo>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
        <initialAllowAutoRefuel>true</initialAllowAutoRefuel>
        <hideGizmosIfNotPlayerFaction>false</hideGizmosIfNotPlayerFaction>
        <fuelLabel>HD_Aircraft_FuelLabel</fuelLabel>
        <fuelGizmoLabel>HD_Aircraft_FuelGizmoLabel</fuelGizmoLabel>
        <fuelFilter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </fuelFilter>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftFuelSelector" />
      <li Class="Helodrace.Aircraft.CompProperties_AircraftManifest">
        <passengerCapacity>0</passengerCapacity>
        <cargoCapacity>40</cargoCapacity>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftTransporter">
        <massCapacity>40</massCapacity>
        <max1PerGroup>true</max1PerGroup>
        <canChangeAssignedThingsAfterStarting>true</canChangeAssignedThingsAfterStarting>
        <shouldTickContents>true</shouldTickContents>
        <showMassInInspectString>true</showMassInInspectString>
        <showOverallStats>true</showOverallStats>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftBombBay">
        <capacity>1200</capacity>
        <hasCenterSlot>true</hasCenterSlot>
        <wingSlotsPerSide>2</wingSlotsPerSide>
        <minimumImbalancedTurnRateFactor>0.55</minimumImbalancedTurnRateFactor>
        <defaultMaxCountPerSlot>1</defaultMaxCountPerSlot>
        <bombSlotLimits>
          <li>
            <bombDef>HD_Bomb_AN_M64_500lb</bombDef>
            <maxCountPerSlot>1</maxCountPerSlot>
          </li>
        </bombSlotLimits>
        <allowedBombTags>
          <li>HD_ANSlot</li>
        </allowedBombTags>
      </li>
      <li Class="Helodrace.Aircraft.CompProperties_AircraftGun">
        <gunDef>HD_Gun_M2HB_TurretGun</gunDef>
        <mountType>Fixed</mountType>
        <strafeLength>14</strafeLength>
        <strafeWidth>5</strafeWidth>
        <strafeAltitude>12</strafeAltitude>
        <roundsPerMinute>850</roundsPerMinute>
        <gunCount>8</gunCount>
        <fireLeadDistance>16</fireLeadDistance>
        <maxApproachTurnAngle>35</maxApproachTurnAngle>
        <approachRadius>1.5</approachRadius>
        <recoveryDistance>16</recoveryDistance>
      </li>
    </comps>
  </ThingDef>

</Defs>
