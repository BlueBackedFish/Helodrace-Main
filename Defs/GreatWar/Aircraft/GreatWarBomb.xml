<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef ParentName="ResourceBase">
    <defName>HD_Bomb_230lb_MkI</defName>
    <label>230-pound Mk I bomb</label>
    <description>A 230-pound high-explosive aerial bomb carried by Great War light bombers. Its simple impact fuze and heavy explosive filling make it effective against troops, fieldworks, and lightly protected structures.</description>
    <graphicData>
      <texPath>Aerocraft/Ammo/HD_230MKIHD</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.15,1.15)</drawSize>
    </graphicData>
    <stackLimit>10</stackLimit>
    <statBases>
      <MarketValue>220</MarketValue>
      <Mass>104.3</Mass>
      <MaxHitPoints>90</MaxHitPoints>
      <Flammability>0.7</Flammability>
      <DeteriorationRate>0.5</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeTags>
      <li>HD_AircraftBomb</li>
    </tradeTags>
    <modExtensions>
      <li Class="Helodrace.Aircraft.AircraftBombDefExtension">
        <projectile>HD_Projectile_230lb_MkI</projectile>
        <bombTags>
          <li>HD_AircraftBomb</li>
        </bombTags>
        <fallSpeed>0.30</fallSpeed>
        <weaponRange>35</weaponRange>
        <horizontalScatter>2.5</horizontalScatter>
        <cooldownTicks>45</cooldownTicks>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>HD_Projectile_230lb_MkI</defName>
    <label>230-pound Mk I bomb</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>Aerocraft/Ammo/HD_230MKIHD</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(0.8,0.8)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>100</damageAmountBase>
      <stoppingPower>3</stoppingPower>
      <speed>30</speed>
      <flyOverhead>true</flyOverhead>
      <explosionRadius>4.5</explosionRadius>
      <soundExplode>Explosion_Bomb</soundExplode>
    </projectile>
  </ThingDef>

  <ThingDef ParentName="ResourceBase">
    <defName>HD_Bomb_AN_M64_500lb</defName>
    <label>AN-M64 500-pound bomb</label>
    <description>A 500-pound general-purpose aerial bomb with a substantial high-explosive filling. It is effective against troops, vehicles, fortifications, and buildings.</description>
    <graphicData>
      <texPath>Aerocraft/Ammo/HD_ANM64</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.35,1.35)</drawSize>
    </graphicData>
    <stackLimit>10</stackLimit>
    <statBases>
      <MarketValue>440</MarketValue>
      <Mass>227</Mass>
      <MaxHitPoints>110</MaxHitPoints>
      <Flammability>0.7</Flammability>
      <DeteriorationRate>0.5</DeteriorationRate>
    </statBases>
    <thingCategories>
      <li>Manufactured</li>
    </thingCategories>
    <tradeTags>
      <li>HD_AircraftBomb</li>
    </tradeTags>
    <modExtensions>
      <li Class="Helodrace.Aircraft.AircraftBombDefExtension">
        <projectile>HD_Projectile_AN_M64_500lb</projectile>
        <bombTags>
          <li>HD_ANSlot</li>
        </bombTags>
        <fallSpeed>0.36</fallSpeed>
        <weaponRange>40</weaponRange>
        <horizontalScatter>2.8</horizontalScatter>
        <cooldownTicks>55</cooldownTicks>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BaseBullet">
    <defName>HD_Projectile_AN_M64_500lb</defName>
    <label>AN-M64 500-pound bomb</label>
    <thingClass>Projectile_Explosive</thingClass>
    <graphicData>
      <texPath>Aerocraft/Ammo/HD_ANM64_proj</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.0,1.0)</drawSize>
    </graphicData>
    <projectile>
      <damageDef>Bomb</damageDef>
      <damageAmountBase>180</damageAmountBase>
      <armorPenetrationBase>0.45</armorPenetrationBase>
      <stoppingPower>4</stoppingPower>
      <speed>32</speed>
      <flyOverhead>true</flyOverhead>
      <explosionRadius>6.2</explosionRadius>
      <soundExplode>Explosion_Bomb</soundExplode>
    </projectile>
  </ThingDef>

</Defs>
